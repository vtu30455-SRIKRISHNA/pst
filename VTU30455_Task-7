public class Fibonacci {
    public static void main(String[] args) {
        int n =7; // Find the 9th Fibonacci number
        System.out.println("Fibonacci number at position " + n + " is: " + findNthFibonacci(n));
    }

    public static long findNthFibonacci(int n) {
        // Handle base cases
        if (n <= 0) return 0;
        if (n == 1) return 1;

        long prev2 = 0; // F(0)
        long prev1 = 1; // F(1)
        long current = 0;

        for (int i = 2; i <= n; i++) {
            current = prev1 + prev2;
            prev2 = prev1;
            prev1 = current;
        }

        return current;
    }
}
