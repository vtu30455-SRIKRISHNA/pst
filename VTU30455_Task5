public class PrintPairs {
    public static void main(String[] args) {
        int[] arr = {1, 2, 3, 4}; // Size N = 4
        int n = arr.length;

        System.out.println("All unique pairs:");
        for (int i = 0; i < n; i++) {
            for (int j = i + 1; j < n; j++) {
                System.out.println("(" + arr[i] + ", " + arr[j] + ")");
            }
        }
    }
}
